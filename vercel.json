{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb", "maxDuration": 60 }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/analisar/(.*)", "dest": "/api/index.py" },
    { "src": "/gerar/(.*)",    "dest": "/api/index.py" },
    { "src": "/historico(.*)", "dest": "/api/index.py" },
    { "src": "/health",        "dest": "/api/index.py" },
    { "src": "/docs(.*)",      "dest": "/api/index.py" },
    { "src": "/openapi.json",  "dest": "/api/index.py" },
    { "src": "/(.*)",          "dest": "/frontend/$1"  }
  ]
}
